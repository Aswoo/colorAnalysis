digraph findColor {
    graph [
        rankdir=LR
        fontname="Helvetica Neue"
        bgcolor="#F0F2F5"
        pad=0.7
        splines=polyline
        nodesep=0.45
        ranksep=1.3
        compound=true
    ]
    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        margin="0.22,0.11"
        penwidth=1.3
    ]
    edge [
        fontname="Helvetica Neue"
        fontsize=9
        penwidth=1.2
        arrowsize=0.75
    ]

    // ════════════════════════════════════════
    //  FRONTEND
    // ════════════════════════════════════════
    subgraph cluster_fe {
        label="Frontend  ·  React 19 + TypeScript"
        fontname="Helvetica Neue Bold" fontsize=12
        style="filled,rounded"
        color="#1A73E8" fillcolor="#E8F0FE"
        margin=16

        node [fillcolor="#FFFFFF" color="#1A73E8" fontcolor="#202124"]
        pg_home    [label="Home\n업로드·색상 선택"]
        pg_history [label="History\n분석 히스토리"]
        pg_login   [label="Login / Signup"]

        svc_analysis [label="analysisService\n(2.5s 폴링)"]
        svc_auth     [label="authService"]

        node [fillcolor="#1A73E8" color="#0D47A1" fontcolor="#FFFFFF" penwidth=1.5]
        fe_api [label="apiClient\naxios + JWT interceptor"]

        pg_home    -> svc_analysis [style=dashed color="#7BAAF7"]
        pg_history -> svc_analysis [style=dashed color="#7BAAF7"]
        pg_login   -> svc_auth     [style=dashed color="#7BAAF7"]
        svc_analysis -> fe_api     [color="#1A73E8"]
        svc_auth     -> fe_api     [color="#1A73E8"]
    }

    // ════════════════════════════════════════
    //  BACKEND
    // ════════════════════════════════════════
    subgraph cluster_be {
        label="Backend  ·  Spring Boot 3.4"
        fontname="Helvetica Neue Bold" fontsize=12
        style="filled,rounded"
        color="#1E8449" fillcolor="#EAF7EF"
        margin=16

        // Security
        subgraph cluster_sec {
            label="Security"
            fontsize=10 style="filled,rounded"
            color="#27AE60" fillcolor="#C8F0D8" margin=10
            node [fillcolor="#FFFFFF" color="#1E8449" fontcolor="#202124"]
            sec_jwt   [label="JwtAuthorizationFilter"]
            sec_login [label="CustomLoginFilter"]
        }

        // Controller
        subgraph cluster_ctl {
            label="Controller"
            fontsize=10 style="filled,rounded"
            color="#27AE60" fillcolor="#C8F0D8" margin=10
            node [fillcolor="#FFFFFF" color="#1E8449" fontcolor="#202124"]
            ctl_auth    [label="AuthController"]
            ctl_mission [label="MissionImageController"]
            ctl_history [label="AnalysisController"]
        }

        // Service + Color Analysis Core (같은 레이어)
        subgraph cluster_svc {
            label="Service"
            fontsize=10 style="filled,rounded"
            color="#27AE60" fillcolor="#C8F0D8" margin=10
            node [fillcolor="#FFFFFF" color="#1E8449" fontcolor="#202124"]
            svc_user    [label="UserService"]
            svc_mission [label="MissionService"]
            svc_s3      [label="S3Service"]
            svc_color   [label="ColorAnalysisService\n@Async"]
        }

        subgraph cluster_core {
            label="Color Analysis Core"
            fontsize=10 style="filled,rounded"
            color="#E67E22" fillcolor="#FEF0E0" margin=10
            node [fillcolor="#FFFFFF" color="#E67E22" fontcolor="#202124"]
            core_kmeans [label="K-means K=8\nLab 공간"]
            core_lch    [label="LCH Hue 각도\natan2(b,a)"]
            core_enum   [label="ColorType Enum\n유사도 계산"]
            core_kmeans -> core_lch -> core_enum [color="#E67E22" penwidth=1.5]
        }

        // Repository
        subgraph cluster_repo {
            label="Repository"
            fontsize=10 style="filled,rounded"
            color="#27AE60" fillcolor="#C8F0D8" margin=10
            node [fillcolor="#FFFFFF" color="#1E8449" fontcolor="#202124"]
            repo_user   [label="UserRepository"]
            repo_req    [label="AnalysisRequestRepository"]
            repo_result [label="AnalysisResultRepository"]
            repo_color  [label="DetectedColorRepository"]
        }

        // Core를 Service 다음 열에 오도록 앵커
        svc_color -> core_kmeans   [color="#E67E22" penwidth=1.5]
        // Core → Repository 연결로 열 순서 확정
        core_enum -> repo_result   [style=invis]

        // Security → Controller
        sec_login -> ctl_auth    [color="#27AE60"]
        sec_jwt   -> ctl_mission [color="#27AE60"]
        sec_jwt   -> ctl_history [color="#27AE60"]

        // Controller → Service
        ctl_auth    -> svc_user    [color="#1E8449"]
        ctl_mission -> svc_mission [color="#1E8449"]
        ctl_mission -> svc_color   [color="#1E8449"]
        ctl_history -> svc_mission [color="#1E8449"]
        svc_mission -> svc_s3      [color="#1E8449" style=dashed]

        // Service → Repository
        svc_user    -> repo_user   [style=dashed color="#58D68D"]
        svc_mission -> repo_req    [style=dashed color="#58D68D"]
        svc_color   -> repo_result [style=dashed color="#58D68D"]
        svc_color   -> repo_color  [style=dashed color="#58D68D"]
        svc_color   -> repo_req    [style=dashed color="#58D68D"]
    }

    // ════════════════════════════════════════
    //  INFRASTRUCTURE
    // ════════════════════════════════════════
    subgraph cluster_infra {
        label="Infrastructure"
        fontname="Helvetica Neue Bold" fontsize=12
        style="filled,rounded"
        color="#7D3C98" fillcolor="#F4ECF7"
        margin=20

        infra_db [
            label="findcolor DB"
            shape=none image="images/mysql_icon_sm.png"
            imagescale=true labelloc=b
            width=1.6 height=1.0
            fontsize=10 fontcolor="#202124"
        ]
        infra_s3 [
            label="이미지 원본 저장"
            shape=none image="images/s3_icon.png"
            imagescale=true labelloc=b
            width=1.2 height=1.5
            fontsize=10 fontcolor="#202124"
        ]
        // 세로로 배치
        infra_db -> infra_s3 [style=invis]
    }

    // ════════════════════════════════════════
    //  CROSS-CLUSTER EDGES
    // ════════════════════════════════════════
    fe_api -> sec_login [
        label=" POST /api/auth/login"
        color="#1A73E8" fontcolor="#1A73E8" penwidth=2
    ]
    fe_api -> sec_jwt [
        label=" REST + JWT Bearer"
        color="#1A73E8" fontcolor="#1A73E8" penwidth=2
    ]
    svc_s3 -> infra_s3 [
        label=" PutObject"
        color="#FF9900" fontcolor="#FF9900" penwidth=2
    ]
    repo_user   -> infra_db [color="#7D3C98" penwidth=1.5]
    repo_req    -> infra_db [color="#7D3C98" penwidth=1.5]
    repo_result -> infra_db [color="#7D3C98" penwidth=1.5]
    repo_color  -> infra_db [color="#7D3C98" penwidth=1.5]
}
